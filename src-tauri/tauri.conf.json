{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bunun Mazen Pharmacy",
  "version": "2.3.0",
  "identifier": "com.bununmazen.pharmacy",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Bunun Mazen Pharmacy",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https://*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Bunun Mazen Pharmacy",
    "category": "Business",
    "shortDescription": "Bunun Mazen Pharmacy Management System",
    "longDescription": "Electronic pharmacy management system for Bunun Mazen Pharmacy."
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/JJ36t/bunun-mazen-pharmacy/releases/latest/download/latest.json"
      ],
      "pubkey": "UPDATER_PUBKEY_MUST_BE_SET_BEFORE_RELEASE",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}